{
  "compilerOptions": {
    "target": "ESNext",
    "module": "nodenext",
    "jsx": "react-jsx",
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "noImplicitAny": true,
    "sourceMap": true,
    "outDir": "dist",
    "moduleResolution": "nodenext",
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "shared": ["./src/shared"],
      "components": ["./src/components"],
      "constants": ["./src/constants"],
      "layouts": ["./src/layouts"],
      "pages": ["./src/pages"],
      "routes": ["./src/routes"],
      "services": ["./src/services"],
      "store": ["./src/store"],
      "types": ["./src/types"],
      "utils": ["./src/utils"],

      "shared/*": ["./src/shared/*"],
      "components/*": ["./src/components/*"],
      "constants/*": ["./src/constants/*"],
      "layouts/*": ["./src/layouts/*"],
      "pages/*": ["./src/pages/index", "./src/pages/*"],
      "routes/*": ["./src/routes/*"],
      "services/*": ["./src/services/*"],
      "store/*": ["./src/store/*"],
      "types/*": ["./src/types/*"],
      "utils/*": ["./src/utils/*"]
    }
  },
  "include": ["src"]
}
